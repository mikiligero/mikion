# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# entorno de ejemplo sí se versiona
!.env.example

# archivos subidos por los usuarios
uploads/

# Resultados de ejecución de pruebas de UI (artefactos locales, no versionados).
# Los juegos de pruebas (qa-completo.md, regresion-media.md) sí se versionan;
# solo se ignoran las ejecuciones concretas y sus capturas.
/testing/ejecuciones/*
!/testing/ejecuciones/_TEMPLATE.md
/testing/assets/*
