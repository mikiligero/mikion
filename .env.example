# Conexión a PostgreSQL
DATABASE_URL=postgres://notion:notion@localhost:5433/notion
# Secreto para firmar sesiones (genera uno con: openssl rand -base64 32)
BETTER_AUTH_SECRET=
# URL pública de la aplicación
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Directorio donde se guardan los archivos subidos
UPLOADS_DIR=./uploads
# Unsplash (portadas): Access Key gratuita de https://unsplash.com/developers
# (sin ella, la pestaña "Unsplash" del selector de portada queda desactivada)
UNSPLASH_ACCESS_KEY=
