# Conexión a PostgreSQL (desarrollo local; Postgres dev en el puerto 5433)
DATABASE_URL=postgres://notion:notion@localhost:5433/notion
# Contraseña de Postgres en producción (docker-compose.prod.yml). Obligatoria;
# genera una fuerte, p. ej.: openssl rand -base64 24
POSTGRES_PASSWORD=
# Secreto para firmar sesiones (genera uno con: openssl rand -base64 32)
BETTER_AUTH_SECRET=
# URL pública de la app. EN PRODUCCIÓN debe ser la URL real con la que accedes,
# incluido https:// (p. ej. https://mikion.midominio.com). Si no coincide con el
# origen del navegador, el login falla por la verificación CSRF de Better Auth.
BETTER_AUTH_URL=http://localhost:3000
# (Opcional) orígenes de confianza adicionales separados por comas, si accedes
# por varias URLs (p. ej. dominio HTTPS + IP de la LAN):
# BETTER_AUTH_TRUSTED_ORIGINS=https://mikion.midominio.com,http://192.168.1.50:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Registro de cuentas: cerrado por defecto. Para crear una cuenta nueva, pon
# esto a "true", recrea el contenedor, regístrate en /register y vuelve a
# dejarlo en blanco (o "false") y recrea otra vez.
MIKION_ALLOW_SIGNUP=
# Directorio donde se guardan los archivos subidos
UPLOADS_DIR=./uploads
# Unsplash (portadas): Access Key gratuita de https://unsplash.com/developers
# (sin ella, la pestaña "Unsplash" del selector de portada queda desactivada)
UNSPLASH_ACCESS_KEY=
# Telegram (notificaciones): token del bot creado con @BotFather.
# El chat_id de cada usuario se configura en Ajustes › Preferencias.
TELEGRAM_BOT_TOKEN=
