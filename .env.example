# Conexión a PostgreSQL (desarrollo local; Postgres dev en el puerto 5433)
DATABASE_URL=postgres://notion:notion@localhost:5433/notion
# Contraseña de Postgres en producción (docker-compose.prod.yml). Obligatoria;
# genera una fuerte, p. ej.: openssl rand -base64 24
POSTGRES_PASSWORD=
# Secreto para firmar sesiones (genera uno con: openssl rand -base64 32)
BETTER_AUTH_SECRET=
# URL pública de la aplicación
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Directorio donde se guardan los archivos subidos
UPLOADS_DIR=./uploads
# Unsplash (portadas): Access Key gratuita de https://unsplash.com/developers
# (sin ella, la pestaña "Unsplash" del selector de portada queda desactivada)
UNSPLASH_ACCESS_KEY=
# Telegram (notificaciones): token del bot creado con @BotFather.
# El chat_id de cada usuario se configura en Ajustes › Preferencias.
TELEGRAM_BOT_TOKEN=
